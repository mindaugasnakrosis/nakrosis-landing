{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "nakrosis",
  "main": "worker.js",
  "compatibility_date": "2026-04-28",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
